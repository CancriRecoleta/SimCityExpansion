// ============================================================
//  BuildPack · Litematica（投影）风格 —— 唯一样式表
//
//  布局与配色逐项对照 malilib / Litematica 源码：
//    整屏遮罩      GuiBase.TOOLTIP_BACKGROUND   #b0000000
//    列表/面板外框 drawOutlinedBox               底 #a0000000 + 边 #999999
//    行悬停/选中   WidgetDirectoryEntry          #70ffffff
//    信息面板      WidgetSchematicBrowser        宽 170，标签 #c0c0c0、值白
//    按钮          ButtonGeneric                 原版 widget/button 九宫格，高 20，
//                                                文字 #e0e0e0（禁用 #a0a0a0）
//    文字          全部白字带阴影（原版字体，行高 9px，中文低于 9 缺笔画）
// ============================================================

// ---- 屏幕骨架 ----
.buildpack-root {
  background: rect(#b0000000);
}

.buildpack-browser {
  background: sdf(#a0000000, 0, 1, #999999);
}

.buildpack-detail {
  background: sdf(#a0000000, 0, 1, #999999);
}

.buildpack-preview {
  background: sdf(#30000000, 0, 1, #999999);
}

.buildpack-status {
  padding-all: 1;
}

// ---- 文本 ----
text, label {
  text-color: #ffffff;
  text-shadow: true;
  font-size: 9;
}

.buildpack-title {
  text-color: #ffffff;
  font-size: 10;
}

// 信息行标签灰、值白（值的白色由代码侧组件样式提供）。
.buildpack-info-row {
  text-color: #c0c0c0;
}

.buildpack-form-title {
  text-color: #ffffff;
}

.buildpack-form-label {
  text-color: #c0c0c0;
}

.buildpack-preview-none {
  text-color: #808080;
}

.buildpack-material-row {
  text-color: #c0c0c0;
}

.buildpack-material-missing {
  text-color: #ff6060;
}

.buildpack-status-count {
  text-color: #a0a0a0;
}

.buildpack-status-message {
  text-color: #55ff55;
}

.buildpack-status-message.buildpack-status-error {
  text-color: #ff6060;
}

.buildpack-status-hint {
  text-color: #808080;
}

// ---- 文件列表 ----
.buildpack-tree {
  node-hover-background: rect(#70ffffff);
  leaf-hover-background: rect(#70ffffff);
}

// 列表直接坐在 0xA0000000 的浏览器底上，滚动视口不再垫色。
.__scroller_view_view-port__ {
  background: empty;
}

// ---- 控件（原版按钮 = Litematica ButtonGeneric 同款九宫格精灵）----
button:host {
  base-background: vanilla-sprite(minecraft:widget/button);
  hover-background: vanilla-sprite(minecraft:widget/button_highlighted);
  pressed-background: vanilla-sprite(minecraft:widget/button_highlighted);
  padding-all: 4;
  height: 20;
}

.__button_text__ {
  text-color: #e0e0e0;
}

button.__disabled__ {
  base-background: vanilla-sprite(minecraft:widget/button_disabled);
}

button.__disabled__ .__button_text__ {
  text-color: #a0a0a0;
}

// 输入框：原版 EditBox 观感（黑底灰边，聚焦白边）。
text-field:host {
  background: sdf(#ee000000, 0, 1, #a0a0a0);
  focus-overlay: sdf(#00000000, 0, 1, #ffffff);
  padding-all: 2;
}

selector:host {
  background: sdf(#ee000000, 0, 1, #a0a0a0);
  focus-overlay: sdf(#00000000, 0, 1, #ffffff);
}

.__selector_dialog__ {
  background: sdf(#f0101010, 0, 1, #999999);
}

// 勾选框（来源页签 .buildpack-tab + 表单「覆盖同名建筑」.buildpack-form-overwrite）：
// 统一在代码侧（UiCheckbox）设置为「空框 / 带勾框」复选框并去掉按钮底，
// 这里不再写任何 toggle / .__toggle_button__ 样式，以免覆盖代码设置的复选框贴图。
// 文字仍走上方通用的 text/label 规则（白字带阴影）。
